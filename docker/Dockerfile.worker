# Dockerfile for Heddle LLM/processor workers.
# Build: docker build -f docker/Dockerfile.worker -t heddle-worker .
# Run:   docker run -e WORKER_CONFIG=configs/workers/summarizer.yaml \
#                   -e MODEL_TIER=local \
#                   -e NATS_URL=nats://nats:4222 \
#                   -e OLLAMA_URL=http://ollama:11434 \
#                   heddle-worker
#
# For processor workers (e.g., DoclingBackend), the consumer package
# must also be installed. See docman/Dockerfile for an example.
FROM python:3.12-slim

WORKDIR /app

COPY pyproject.toml .
RUN pip install --no-cache-dir .

COPY src/ src/
COPY configs/ configs/

# Worker type and tier set via environment variables
ENV WORKER_CONFIG="configs/workers/summarizer.yaml"
ENV MODEL_TIER="local"
ENV NATS_URL="nats://nats:4222"

COPY docker/entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
