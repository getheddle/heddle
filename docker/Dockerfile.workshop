FROM python:3.12-slim

WORKDIR /app

# Install build dependencies
RUN pip install --no-cache-dir uv

# Copy project files
COPY pyproject.toml .
COPY src/ src/
COPY configs/ configs/

# Install heddle with workshop extras
RUN uv pip install --system ".[workshop]"

# Create apps directory for deployed bundles
RUN mkdir -p /root/.heddle/apps

EXPOSE 8080

CMD ["heddle", "workshop", "--host", "0.0.0.0", "--port", "8080", "--configs-dir", "configs/"]
