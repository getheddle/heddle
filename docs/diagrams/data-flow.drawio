        </mxCell>

        <!-- LLM Backend -->
        <mxCell id="llm" value="LLM Backend&#xa;Anthropic / Ollama" style="shape=cylinder3;whiteSpace=wrap;html=1;boundedLbl=1;backgroundOutline=1;size=10;fillColor=#e1d5e7;strokeColor=#9673a6;" vertex="1" parent="1">
          <mxGeometry x="470" y="320" width="120" height="70" as="geometry" />
        </mxCell>

        <!-- Arrows -->
        <mxCell id="e1" style="endArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="input" target="step1">
