        <mxCell id="e-browser-ws" style="endArrow=classic;startArrow=classic;html=1;rounded=0;" edge="1" parent="1" source="browser" target="workshop">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
